<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.algorithm.mapper.MrpinfoMapper">
    
    <resultMap type="Mrpinfo" id="MrpinfoResult">
        <result property="itemCode"    column="itemCode"    />
        <result property="averageAvailability"    column="averageAvailability"    />
    </resultMap>

    <sql id="selectMrpinfoVo">
        select itemCode, averageAvailability from mrpinfo
    </sql>

    <select id="selectMrpinfoList" parameterType="Mrpinfo" resultMap="MrpinfoResult">
        <include refid="selectMrpinfoVo"/>
        <where>  
            <if test="itemCode != null  and itemCode != ''"> and itemCode like concat('%', #{itemCode}, '%')</if>
            <if test="averageAvailability != null "> and averageAvailability = #{averageAvailability}</if>
        </where>
    </select>
    
    <select id="selectMrpinfoByItemCode" parameterType="String" resultMap="MrpinfoResult">
        <include refid="selectMrpinfoVo"/>
        where itemCode = #{itemCode}
    </select>
        
    <insert id="insertMrpinfo" parameterType="Mrpinfo">
        insert into mrpinfo
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="itemCode != null">itemCode,</if>
            <if test="averageAvailability != null">averageAvailability,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="itemCode != null">#{itemCode},</if>
            <if test="averageAvailability != null">#{averageAvailability},</if>
         </trim>
    </insert>

    <update id="updateMrpinfo" parameterType="Mrpinfo">
        update mrpinfo
        <trim prefix="SET" suffixOverrides=",">
            <if test="averageAvailability != null">averageAvailability = #{averageAvailability},</if>
        </trim>
        where itemCode = #{itemCode}
    </update>

    <delete id="deleteMrpinfoByItemCode" parameterType="String">
        delete from mrpinfo where itemCode = #{itemCode}
    </delete>

    <delete id="deleteMrpinfoByItemCodes" parameterType="String">
        delete from mrpinfo where itemCode in 
        <foreach item="itemCode" collection="array" open="(" separator="," close=")">
            #{itemCode}
        </foreach>
    </delete>
</mapper>
