<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.algorithm.mapper.OpminfoMapper">
    
    <resultMap type="Opminfo" id="OpminfoResult">
        <result property="itemCode"    column="itemCode"    />
        <result property="dailyUsage"    column="dailyUsage"    />
        <result property="orderPoint"    column="orderPoint"    />
        <result property="maxPoint"    column="maxPoint"    />
    </resultMap>

    <sql id="selectOpminfoVo">
        select itemCode, dailyUsage, orderPoint, maxPoint from opminfo
    </sql>

    <select id="selectOpminfoList" parameterType="Opminfo" resultMap="OpminfoResult">
        <include refid="selectOpminfoVo"/>
        <where>  
            <if test="itemCode != null  and itemCode != ''"> and itemCode like concat('%', #{itemCode}, '%')</if>
            <if test="dailyUsage != null "> and dailyUsage = #{dailyUsage}</if>
            <if test="orderPoint != null "> and orderPoint = #{orderPoint}</if>
            <if test="maxPoint != null "> and maxPoint = #{maxPoint}</if>
        </where>
    </select>
    
    <select id="selectOpminfoByItemCode" parameterType="String" resultMap="OpminfoResult">
        <include refid="selectOpminfoVo"/>
        where itemCode = #{itemCode}
    </select>
        
    <insert id="insertOpminfo" parameterType="Opminfo">
        insert into opminfo
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="itemCode != null">itemCode,</if>
            <if test="dailyUsage != null">dailyUsage,</if>
            <if test="orderPoint != null">orderPoint,</if>
            <if test="maxPoint != null">maxPoint,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="itemCode != null">#{itemCode},</if>
            <if test="dailyUsage != null">#{dailyUsage},</if>
            <if test="orderPoint != null">#{orderPoint},</if>
            <if test="maxPoint != null">#{maxPoint},</if>
         </trim>
    </insert>

    <update id="updateOpminfo" parameterType="Opminfo">
        update opminfo
        <trim prefix="SET" suffixOverrides=",">
            <if test="dailyUsage != null">dailyUsage = #{dailyUsage},</if>
            <if test="orderPoint != null">orderPoint = #{orderPoint},</if>
            <if test="maxPoint != null">maxPoint = #{maxPoint},</if>
        </trim>
        where itemCode = #{itemCode}
    </update>

    <delete id="deleteOpminfoByItemCode" parameterType="String">
        delete from opminfo where itemCode = #{itemCode}
    </delete>

    <delete id="deleteOpminfoByItemCodes" parameterType="String">
        delete from opminfo where itemCode in 
        <foreach item="itemCode" collection="array" open="(" separator="," close=")">
            #{itemCode}
        </foreach>
    </delete>
</mapper>
